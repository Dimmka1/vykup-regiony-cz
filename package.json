{
  "name": "vykup-regiony-cz-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "prepare": "husky",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "ci": "npm run lint && npm run format:check && tsc --noEmit && npm run build",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "framer-motion": "^12.35.0",
    "lucide-react": "^0.575.0",
    "next": "^15.5.12",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "web-vitals": "^5.1.0",
    "yaml": "^2.7.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.2",
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.3",
    "eslint-config-next": "^15.1.6",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "postcss": "^8.4.49",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,json,md,yml,yaml,css}": "prettier --write",
